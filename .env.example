# ── DATABASE ──
# Get a free Postgres DB at supabase.com or railway.app
DATABASE_URL="postgresql://user:password@host:5432/govsignal"

# ── AUTH ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ── SERVER ──
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"  # Your React app URL

# ── STRIPE ──
# Get from dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."      # $49/mo plan — create in Stripe dashboard
STRIPE_AGENCY_PRICE_ID="price_..."   # $149/mo plan

# ── EMAIL (Nodemailer) ──
# Use Resend.com (free 3k emails/mo) or SendGrid
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_your_api_key"
EMAIL_FROM="GovSignal <noreply@govsignal.io>"

# ── SAM.GOV ──
# System account key for server-side fetching (1000 req/day)
# Get at sam.gov → Profile → System Account
SAM_GOV_API_KEY="your-sam-gov-system-api-key"

# ── OPTIONAL: OPENAI (for enhanced AI scoring) ──
OPENAI_API_KEY="sk-..."
