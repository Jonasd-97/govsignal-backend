// HelixGov Database Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USERS ──
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Stripe
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  plan                 Plan     @default(FREE)
  planExpiresAt        DateTime?

  // Email verification
  emailVerified Boolean @default(false)

  // Company profile (used for AI scoring)
  companyName      String?
  naicsCode        String?
  setAside         String?
  targetAgency     String?
  yearsInBusiness  String?
  samApiKey        String?

  // AI usage tracking (PRO: 50/mo, AGENCY: unlimited)
  aiUsageCount    Int       @default(0)
  aiUsageResetAt  DateTime?

  // AI-built capability profile (updated each time a doc is dropped)
  // Stores: { capabilityTags, naicsCodes, agencies, dollarRanges, technicalAreas, lastUpdated }
  capabilityProfile Json?

  // Relations
  savedOpps      SavedOpportunity[]
  searches       SavedSearch[]
  pastPerf       PastPerformance[]
  digestSettings DigestSettings?
  emailTokens    EmailVerificationToken[]

  @@map("users")
}

enum Plan {
  FREE       // search only, no AI
  PRO        // $49/mo — AI features, daily digest
  AGENCY     // $299/mo — everything + team seats + white-label
}

// ── OPPORTUNITIES (cached from SAM.gov + USASpending) ──
model Opportunity {
  id                    String   @id @default(cuid())
  noticeId              String   @unique
  title                 String
  agency                String?
  subAgency             String?
  naicsCode             String?
  opportunityType       String?
  setAsideType          String?
  setAsideDescription   String?
  postedDate            DateTime?
  responseDeadline      DateTime?
  archiveDate           DateTime?
  description           String?  @db.Text
  uiLink                String?
  solicitationNumber    String?
  placeOfPerformance    String?
  rawJson               Json?
  source                String?  @default("SAM")  // "SAM" | "USASPENDING"

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  savedBy    SavedOpportunity[]

  @@index([naicsCode])
  @@index([responseDeadline])
  @@index([postedDate])
  @@index([source])
  @@map("opportunities")
}

// ── SAVED OPPORTUNITIES (watchlist) ──
model SavedOpportunity {
  id             String      @id @default(cuid())
  userId         String
  opportunityId  String
  notes          String?
  savedAt        DateTime    @default(now())

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@map("saved_opportunities")
}

// ── SAVED SEARCHES ──
model SavedSearch {
  id             String   @id @default(cuid())
  userId         String
  name           String
  filters        Json
  alertOn        Boolean  @default(true)
  lastAlertedAt  DateTime?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

// ── PAST PERFORMANCE ──
model PastPerformance {
  id              String   @id @default(cuid())
  userId          String
  title           String
  agency          String?
  contractValue   Float?
  year            Int?
  outcome         String   @default("Won")
  description     String?  @db.Text
  naicsCode       String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("past_performance")
}

// ── EMAIL DIGEST SETTINGS ──
model DigestSettings {
  id           String    @id @default(cuid())
  userId       String    @unique
  enabled      Boolean   @default(true)
  frequency    String    @default("daily")
  sendTime     String    @default("08:00")
  minScore     Int       @default(60)
  lastSentAt   DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("digest_settings")
}

// ── EMAIL VERIFICATION TOKENS ──
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}
